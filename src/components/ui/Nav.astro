---
import { navLinks } from '~/data/nav';
import Button from './Button.astro';
---
<nav data-nav class="fixed top-0 left-0 right-0 z-50 flex h-16 items-center justify-between px-6 md:px-12 bg-surface-deep/70 backdrop-blur-md">
  <a href="/" class="font-display text-xl">Elysee</a>
  <ul class="hidden md:flex items-center gap-8 font-mono text-[11px] uppercase tracking-[0.18em] text-text-secondary">
    {navLinks.map(link => (
      <li><a href={link.href} class="transition-colors hover:text-accent-bright">{link.label}</a></li>
    ))}
  </ul>
  <Button href="/#contact" class="hidden md:inline-flex">Get in touch</Button>
  <button data-nav-toggle class="md:hidden text-accent-bright text-2xl leading-none" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">☰</button>
</nav>

<div
  id="mobile-menu"
  data-mobile-menu
  class="fixed inset-0 z-40 hidden flex-col items-center justify-center gap-8 bg-surface-deep/95 backdrop-blur-xl md:!hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Site navigation"
>
  {navLinks.map(link => (
    <a href={link.href} class="font-display text-4xl tracking-[-0.02em] hover:text-accent-bright transition-colors" data-mobile-link>{link.label}</a>
  ))}
  <a href="/#contact" class="mt-4 font-mono text-[11px] uppercase tracking-[0.18em] text-accent-bright border border-accent-primary rounded-full px-6 py-3" data-mobile-link>Get in touch</a>
</div>

<script>
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');

  if (nav) {
    let last = 0;
    const onScroll = () => {
      const y = window.scrollY;
      const hidden = y > last && y > 80;
      nav.style.transform = hidden ? 'translateY(-100%)' : 'translateY(0)';
      nav.inert = hidden;
      last = y;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  if (toggle && menu) {
    const close = () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.textContent = '☰';
      toggle.setAttribute('aria-label', 'Open menu');
      document.body.style.overflow = '';
    };
    const open = () => {
      menu.classList.remove('hidden');
      menu.classList.add('flex');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.textContent = '✕';
      toggle.setAttribute('aria-label', 'Close menu');
      document.body.style.overflow = 'hidden';
    };
    toggle.addEventListener('click', () => {
      toggle.getAttribute('aria-expanded') === 'true' ? close() : open();
    });
    menu.querySelectorAll('[data-mobile-link]').forEach(link => link.addEventListener('click', close));
    document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
  }
</script>

<style>
  nav { transition: transform 0.35s cubic-bezier(0.65, 0, 0.35, 1); }
</style>
